@{

    ViewBag.Title = "Sign Up";

    Layout = "~/Views/Shared/_Layout1.cshtml";

}

<section class="page-hero"
         style="background-image: url('@Url.Content("~/Images/background.jpg")');"
         aria-label="Hero background">
    <div class="form-container form-container--elevated">
        <h2>Sign Up</h2>

        <form asp-action="SignUp" asp-controller="Home" method="post">
            <!-- Full Name -->
            @Html.AntiForgeryToken()
            <input type="text" id="name" name="Name" placeholder="Name" required />
            <span class="error" id="nameError"></span>


            <!-- Email -->
            <input type="email" id="email" name="Email" placeholder="Email" required />
            <span class="error" id="emailError"></span>


            <!-- Mobile -->
            <input type="text" id="mobilenumber" name="MobileNumber" placeholder="Mobile Number" required />
            <span class="error" id="mobileError"></span>


            <div class="password-wrapper">
                <input type="password" id="password" name="Password" placeholder="Password" required />
                <button type="button"
                        class="toggle-password"
                        data-target="password"
                        aria-label="Show password"
                        aria-pressed="false">
                    <i class="fa fa-eye" aria-hidden="true"></i>
                </button>
            </div>
            <span class="error" id="passwordError"></span>

            <div class="password-wrapper">
                <input type="password" id="confirmPassword" name="ConfirmPassword" placeholder="Re-enter Password" required />
                <button type="button"
                        class="toggle-password"
                        data-target="confirmPassword"
                        aria-label="Show password"
                        aria-pressed="false">
                    <i class="fa fa-eye" aria-hidden="true"></i>
                </button>
            </div>
            <span class="error" id="confirmPasswordError"></span>

            <!-- Submit -->
            <button type="submit" class="btn">Sign Up</button>
        </form>
    </div>
</section>

@if (TempData["SuccessMessage"] != null)

{
    <script>

        alert('@TempData["SuccessMessage"]');
    </script>

}

@if (TempData["ErrorMessage"] != null)

{
    <script> alert('@TempData["ErrorMessage"]'); </script>

}


