@model PackageFoodManagementSystem.Repository.Models.Product

@{

    ViewData["Title"] = "Store Manager - Add Product";

    Layout = "~/Views/Shared/_StoreManagerlayout.cshtml";

}

<style>

    .form-container {
        max-width: 600px;
        margin: 50px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .form-header {
        text-align: center;
        margin-bottom: 25px;
    }

        .form-header h2 {
            font-weight: 700;
            color: #333;
        }

        .form-header p {
            color: #777;
        }

    .form-label {
        font-weight: 600;
        color: #555;
    }

    .form-control:focus {
        border-color: #d122e3;
        box-shadow: 0 0 0 0.2rem rgba(209, 34, 227, 0.25);
    }

    .btn-save {
        background: linear-gradient(135deg, #d122e3 0%, #8b129a 100%);
        color: white;
        border: none;
        padding: 12px;
        font-weight: bold;
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(209, 34, 227, 0.4);
            color: white;
        }
</style>
<div class="container">
    <div class="form-container">
        <div class="form-header">
            <h2>Add New Product</h2>
            <p>Enter the details below to add a product to the customer menu.</p>
        </div>

        <form asp-controller="StoreManager1" asp-action="Create" method="post" enctype="multipart/form-data">

            <div class="mb-3">
                <label class="form-label">Product Name</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa fa-tag"></i></span>
                    <input type="text" name="ProductName" class="form-control" placeholder="e.g. Chocolate Cookies" required />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Category</label>
                <select asp-for="Category" class="form-select" required>
                    <option value="">-- Select Category --</option>
                    <option value="Veg & Fruits">Veg & Fruits</option>
                    <option value="Dairy & Eggs">Dairy & Eggs</option>
                    <option value="Snacks & Drinks">Snacks & Drinks</option>
                    <option value="Meat & Fish">Meat & Fish</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Product Image</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fa fa-image"></i></span>
                    <input type="file" name="imageFile" class="form-control" accept="image/*" required />
                </div>
                <small class="text-muted">Recommended size: 500x500px (JPG, PNG)</small>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Price (₹)</label>
                    <input type="number" step="1" name="Price" class="form-control" placeholder="0" required />
                </div>

               
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="activeSwitch" checked>
                    <label class="form-check-label" for="activeSwitch">Available for Customers</label>
                </div>
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-save">
                    <i class="fa fa-plus-circle me-2"></i> Save Product
                </button>
            </div>
        </form>
    </div>
</div>
